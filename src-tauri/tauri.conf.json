{
  "productName": "Fade",
  "version": "0.6.3",
  "identifier": "io.librewin.fade",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1427",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Fade",
        "width": 980,
        "height": 660,
        "minWidth": 720,
        "minHeight": 500,
        "decorations": true,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true,
        "resizable": true,
        "center": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$TEMP/**",
          "/Volumes/**",
          "/media/**",
          "/mnt/**",
          "[A-Z]:/**"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQyNkQ5QzQ4MUI1M0ExOEIKUldTTG9WTWJTSnh0UW0wMDBrM1ZWRjZ2UGdIRVRkQkY1bUpBZnBIQ2VsSkF3Y3R3QzFrbHBKTGwK",
      "endpoints": [
        "https://github.com/eldo9000/Fade-App/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "linux": {
      "deb": {
        "depends": [
          "ffmpeg",
          "imagemagick",
          "assimp-utils"
        ]
      },
      "rpm": {
        "depends": [
          "ffmpeg",
          "ImageMagick",
          "assimp"
        ]
      }
    },
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
